# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{html,j2}]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2

[*.{js,ts}]
indent_style = space
indent_size = 2

[*.{json,jsonc,json5}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.toml]
indent_style = space
indent_size = 2

[Justfile]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2

[*.{ini,cfg,conf}]
indent_style = space
indent_size = 2

[*.{xml,svg}]
indent_style = space
indent_size = 2
